@inject AuthService AuthService

<div class="sidebar-logo">
    <div class="sidebar-logo-icon">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="16 18 22 12 16 6"/>
            <polyline points="8 6 2 12 8 18"/>
        </svg>
    </div>
    <div>
        <span class="sidebar-logo-text">WilayahKu</span>
        <span class="sidebar-logo-sub">Direktori Wilayah Indonesia</span>
    </div>
</div>

<nav class="sidebar-nav">
    <p class="nav-section-title">Navigasi</p>

    <div class="nav-item">
        <NavLink class="nav-link" href="" Match="NavLinkMatch.All" id="nav-home">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
                <polyline points="9 22 9 12 15 12 15 22"/>
            </svg>
            Home
        </NavLink>
    </div>

    <div class="nav-item">
        <NavLink class="nav-link" href="data-wilayah" id="nav-wilayah">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/>
                <circle cx="12" cy="10" r="3"/>
            </svg>
            Data Wilayah
        </NavLink>
    </div>

    <div class="nav-item">
        <NavLink class="nav-link" href="contact" id="nav-contact">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
            Hubungi Kami
        </NavLink>
    </div>

    <div class="nav-item">
        <NavLink class="nav-link" href="about" id="nav-about">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/>
                <line x1="12" y1="16" x2="12" y2="12"/>
                <line x1="12" y1="8" x2="12.01" y2="8"/>
            </svg>
            Tentang Kami
        </NavLink>
    </div>
    <p class="nav-section-title">Akun</p>

    <div class="nav-item">
        @if (AuthService.IsAuthenticated)
        {
            <NavLink class="nav-link" href="akun" id="nav-dashboard">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/>
                </svg>
                Dashboard Akun
            </NavLink>
        }
        else
        {
            <NavLink class="nav-link" href="login" id="nav-login">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
                </svg>
                Login / Register
            </NavLink>
        }
    </div>
</nav>

<div class="sidebar-bottom">
    <p class="sidebar-version">v1.0.0 &bull; WilayahKu</p>
</div>
