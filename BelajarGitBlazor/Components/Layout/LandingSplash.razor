@namespace BelajarGitBlazor.Components.Layout

<div class="landing-container">
    @* Navbar Landing Page *@
    <header class="landing-header">
        <div class="landing-brand">
            <div class="landing-logo-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="16 18 22 12 16 6"/>
                    <polyline points="8 6 2 12 8 18"/>
                </svg>
            </div>
            <div class="landing-brand-text">
                <span class="brand-title">WilayahKu</span>
                <span class="brand-sub">Portal Informasi Wilayah Indonesia</span>
            </div>
        </div>
        <div class="landing-nav-actions">
            <a href="/login" class="btn btn-outline-primary me-2">Masuk (Login)</a>
            <a href="/register" class="btn btn-primary">Daftar Akun</a>
        </div>
    </header>

    @* Hero Section *@
    <section class="landing-hero">
        <div class="hero-badge">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
            <span>Selamat Datang di WilayahKu</span>
        </div>
        <h1 class="landing-title">
            Eksplorasi & Kelola Data Wilayah<br />
            <span class="landing-highlight">Seluruh Indonesia</span>
        </h1>
        <p class="landing-subtitle">
            WilayahKu adalah platform direktori geografis dan administrasi terpadu. Dapatkan akses cepat ke data resmi Provinsi, Kabupaten/Kota, Kecamatan, hingga Desa/Kelurahan lengkap dengan kode wilayah resmi Kemendagri.
        </p>

        <div class="landing-cta-group">
            <a href="/register" class="btn btn-primary btn-cta">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><polyline points="16 11 18 13 22 9"/></svg>
                Daftar Akun Sekarang
            </a>
            <a href="/login" class="btn btn-secondary btn-cta">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" x2="3" y1="12" y2="12"/></svg>
                Sudah Punya Akun? Login
            </a>
        </div>
    </section>

    @* Profil Singkat & Statistik *@
    <section class="landing-stats-section">
        <div class="stat-box">
            <h3>38</h3>
            <p>Provinsi</p>
        </div>
        <div class="stat-box">
            <h3>514</h3>
            <p>Kabupaten / Kota</p>
        </div>
        <div class="stat-box">
            <h3>7,200+</h3>
            <p>Kecamatan</p>
        </div>
        <div class="stat-box">
            <h3>83,000+</h3>
            <p>Desa / Kelurahan</p>
        </div>
    </section>

    @* Fitur Utama *@
    <section class="landing-features">
        <h2 class="section-title">Mengapa Memilih WilayahKu?</h2>
        <p class="section-desc">Nikmati berbagai kemudahan dalam pencarian dan pengelolaan data administratif dengan akun WilayahKu.</p>

        <div class="feature-cards-grid">
            <div class="feature-card">
                <div class="feature-icon primary">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
                </div>
                <h4>Pencarian Cepat & Akurat</h4>
                <p>Cari kode wilayah bertingkat hanya dengan beberapa klik dengan performa super cepat.</p>
            </div>

            <div class="feature-card">
                <div class="feature-icon success">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 12 2 2 4-4"/><circle cx="12" cy="12" r="10"/></svg>
                </div>
                <h4>Data Resmi Kemendagri</h4>
                <p>Seluruh struktur wilayah sinkron dengan rujukan data administratif pemerintahan terbaru.</p>
            </div>

            <div class="feature-card">
                <div class="feature-icon warning">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                </div>
                <h4>Akun & Sesi Tersimpan</h4>
                <p>Daftarkan akun kamu dan gunakan fitur "Ingat Saya" untuk akses instan kapan saja tanpa login ulang.</p>
            </div>
        </div>
    </section>

    @* Footer Landing *@
    <footer class="landing-footer">
        <p>&copy; 2026 WilayahKu. Hak Cipta Dilindungi.</p>
    </footer>
</div>
