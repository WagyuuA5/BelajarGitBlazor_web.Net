@page "/admin/pesan"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@using BelajarGitBlazor.Data.Entities
@inject IPesanKontakService PesanKontakService
@inject AuthService AuthService
@inject NavigationManager NavigationManager
@attribute [Authorize(Roles = "Admin")]

<PageTitle>Pesan Masuk – Admin WilayahKu</PageTitle>

<div class="page-header">
    <div>
        <h1>Pesan Masuk</h1>
        <p>Kelola semua pesan yang masuk dari pengguna WilayahKu.</p>
    </div>
    @if (_pesanBelumDibaca > 0)
    {
        <div class="admin-badge-notif">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
            @_pesanBelumDibaca pesan belum dibaca
        </div>
    }
</div>

@if (_isLoading)
{
    <div style="text-align: center; padding: 40px;">
        <span class="spinner" style="width: 32px; height: 32px;"></span>
        <p style="margin-top: 12px; color: var(--text-muted);">Memuat pesan...</p>
    </div>
}
else if (_pesanList.Count == 0)
{
    <div class="wilayah-empty-state">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        <h3>Belum Ada Pesan</h3>
        <p>Pesan dari pengguna akan tampil di sini.</p>
    </div>
}
else
{
    <div class="wilayah-result-card">
        <div class="table-wrapper">
            <table class="table">
                <thead>
                    <tr>
                        <th>Nama Pengirim</th>
                        <th>Email</th>
                        <th>Cuplikan Pesan</th>
                        <th>Waktu Kirim</th>
                        <th style="text-align: center;">Status</th>
                        <th style="text-align: center; width: 200px;">Aksi</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var pesan in _pesanList)
                    {
                        <tr style="@(pesan.Status == StatusPesan.BelumDibaca ? "font-weight: 600;" : "")">
                            <td>@pesan.NamaPengirim</td>
                            <td style="font-size: 0.9rem; color: var(--text-muted);">@pesan.EmailPengirim</td>
                            <td style="max-width: 220px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                                @(pesan.Isi.Length > 60 ? pesan.Isi[..60] + "..." : pesan.Isi)
                            </td>
                            <td style="font-size: 0.85rem; color: var(--text-muted);">@FormatWaktu(pesan.WaktuKirim)</td>
                            <td style="text-align: center;">
                                @switch (pesan.Status)
                                {
                                    case StatusPesan.BelumDibaca:
                                        <span class="badge" style="background: rgba(239,68,68,0.12); color: #ef4444;">Belum Dibaca</span>
                                        break;
                                    case StatusPesan.SudahDibaca:
                                        <span class="badge" style="background: rgba(234,179,8,0.12); color: #ca8a04;">Sudah Dibaca</span>
                                        break;
                                    case StatusPesan.SudahDitanggapi:
                                        <span class="badge" style="background: var(--success-light); color: var(--success);">Sudah Ditanggapi</span>
                                        break;
                                }
                            </td>
                            <td style="text-align: center;">
                                <div style="display: flex; gap: 6px; justify-content: center; flex-wrap: wrap;">
                                    @if (pesan.Status == StatusPesan.BelumDibaca)
                                    {
                                        <button class="btn btn-outline" style="padding: 4px 10px; font-size: 0.8rem;"
                                                @onclick="() => TandaiDibaca(pesan.Id)" disabled="@_isUpdating">
                                            Tandai Dibaca
                                        </button>
                                    }
                                    @if (pesan.Status != StatusPesan.SudahDitanggapi)
                                    {
                                        <button class="btn btn-primary" style="padding: 4px 10px; font-size: 0.8rem;"
                                                @onclick="() => TandaiDitanggapi(pesan.Id)" disabled="@_isUpdating">
                                            Ditanggapi
                                        </button>
                                    }
                                </div>
                            </td>
                        </tr>

                        @* Detail pesan saat diklik *@
                        @if (_expandedPesanId == pesan.Id)
                        {
                            <tr>
                                <td colspan="6" style="background: var(--card-bg); padding: 16px 20px; border-radius: 8px;">
                                    <strong>Isi Pesan Lengkap:</strong>
                                    <p style="margin: 8px 0 0; white-space: pre-wrap;">@pesan.Isi</p>
                                    @if (!string.IsNullOrEmpty(pesan.UserId))
                                    {
                                        <p style="margin-top: 8px; font-size: 0.85rem; color: var(--text-muted);">
                                            Dikirim oleh akun: <code>@pesan.UserId</code>
                                        </p>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

    <p style="margin-top: 12px; font-size: 0.85rem; color: var(--text-muted);">
        Klik baris pesan untuk melihat detail lengkap.
    </p>
}

@code {
    private List<PesanKontak> _pesanList = new();
    private int _pesanBelumDibaca;
    private bool _isLoading = true;
    private bool _isUpdating = false;
    private int? _expandedPesanId = null;

    protected override async Task OnInitializedAsync()
    {
        // Guard: jika bukan admin, redirect ke home
        if (!AuthService.IsAdmin)
        {
            NavigationManager.NavigateTo("/", replace: true);
            return;
        }

        await MuatData();
    }

    private async Task MuatData()
    {
        _isLoading = true;
        _pesanList = await PesanKontakService.GetSemuaPesanAsync();
        _pesanBelumDibaca = await PesanKontakService.HitungPesanBelumDibacaAsync();
        _isLoading = false;
    }

    private async Task TandaiDibaca(int id)
    {
        _isUpdating = true;
        await PesanKontakService.TandaiSudahDibacaAsync(id);
        await MuatData();
        _isUpdating = false;
    }

    private async Task TandaiDitanggapi(int id)
    {
        _isUpdating = true;
        await PesanKontakService.TandaiSudahDitanggapiAsync(id);
        await MuatData();
        _isUpdating = false;
    }

    private void ToggleDetail(int id)
    {
        _expandedPesanId = _expandedPesanId == id ? null : id;
    }

    private static string FormatWaktu(DateTime dt)
    {
        var diff = DateTime.Now - dt;
        if (diff.TotalMinutes < 1) return "Baru saja";
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes} menit lalu";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours} jam lalu";
        return dt.ToString("dd MMM yyyy, HH:mm", System.Globalization.CultureInfo.GetCultureInfo("id-ID"));
    }
}
