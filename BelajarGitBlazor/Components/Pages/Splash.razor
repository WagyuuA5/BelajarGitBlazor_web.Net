@page "/"
@layout Components.Layout.EmptyLayout
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav

<PageTitle>Selamat Datang di WilayahKu</PageTitle>

<div class="splash-container">
    <div class="splash-content">
        <div class="splash-logo">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/>
                <circle cx="12" cy="10" r="3"/>
            </svg>
        </div>
        <h1 class="splash-title">WilayahKu</h1>
        <p class="splash-desc">
            Portal informasi wilayah terlengkap di Indonesia. Temukan data administrasi dengan cepat, akurat, dan terpercaya.
        </p>
        
        <div class="splash-actions">
            <a href="/login" class="btn btn-primary btn-lg splash-btn">Masuk / Login</a>
            <a href="/register" class="btn btn-secondary btn-lg splash-btn">Daftar Akun Baru</a>
        </div>
    </div>
</div>

<style>
    .splash-container {
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        min-height: 100vh;
        background: linear-gradient(135deg, #fdfbfb 0%, #ebedee 100%);
        padding: 2rem;
        font-family: 'Inter', system-ui, -apple-system, sans-serif;
    }
    
    [data-theme='dark'] .splash-container {
        background: linear-gradient(135deg, #1f2937 0%, #111827 100%);
        color: #f3f4f6;
    }

    .splash-content {
        max-width: 600px;
        text-align: center;
        background: rgba(255, 255, 255, 0.7);
        backdrop-filter: blur(10px);
        padding: 3rem 2rem;
        border-radius: 24px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.3);
    }

    [data-theme='dark'] .splash-content {
        background: rgba(31, 41, 55, 0.7);
        border-color: rgba(255, 255, 255, 0.1);
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
    }

    .splash-logo {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 80px;
        height: 80px;
        background: #2563eb;
        color: white;
        border-radius: 20px;
        margin-bottom: 1.5rem;
        box-shadow: 0 8px 16px rgba(37, 99, 235, 0.3);
    }

    .splash-title {
        font-size: 2.5rem;
        font-weight: 800;
        margin-bottom: 1rem;
        color: #111827;
        letter-spacing: -0.025em;
    }

    [data-theme='dark'] .splash-title {
        color: #f9fafb;
    }

    .splash-desc {
        font-size: 1.125rem;
        line-height: 1.6;
        color: #4b5563;
        margin-bottom: 2.5rem;
    }

    [data-theme='dark'] .splash-desc {
        color: #9ca3af;
    }

    .splash-actions {
        display: flex;
        gap: 1rem;
        justify-content: center;
        flex-wrap: wrap;
    }

    .splash-btn {
        padding: 0.75rem 2rem;
        font-weight: 600;
        border-radius: 9999px;
        transition: all 0.2s;
    }
    
    .splash-btn:hover {
        transform: translateY(-2px);
    }
</style>

@code {
    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        if (authState.User.Identity?.IsAuthenticated == true)
        {
            Nav.NavigateTo("/akun");
        }
    }
}
