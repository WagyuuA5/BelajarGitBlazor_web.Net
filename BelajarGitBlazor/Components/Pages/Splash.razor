@page "/splash"
@layout Components.Layout.EmptyLayout

<PageTitle>Welcome to WilayahKu</PageTitle>

<div class="d-flex flex-column justify-content-center align-items-center vh-100 text-center" style="background-color: #f8f9fa;">
    <div class="mb-4">
        <h1 class="display-3 text-primary fw-bold mb-3">WilayahKu</h1>
        <p class="lead text-secondary" style="max-width: 600px; margin: 0 auto;">
            Platform informasi dan layanan terpadu untuk wilayah kita. Temukan data akurat dan terhubung dengan komunitas sekitarmu dengan mudah dan cepat.
        </p>
    </div>
    
    <div class="mt-4">
        <a href="/login" class="btn btn-primary btn-lg px-5 py-3 me-3 rounded-pill shadow-sm">Mulai (Login)</a>
        <a href="/register" class="btn btn-outline-primary btn-lg px-5 py-3 rounded-pill shadow-sm">Daftar Akun</a>
    </div>
</div>
