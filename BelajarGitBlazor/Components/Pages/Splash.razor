@page "/"
@layout Components.Layout.EmptyLayout
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav

<PageTitle>Selamat Datang di WilayahKu</PageTitle>

<div class="splash-wrapper">
    <!-- Floating background elements for visual interest -->
    <div class="blob blob-1"></div>
    <div class="blob blob-2"></div>
    <div class="blob blob-3"></div>

    <div class="splash-content-box fade-in-up">
        <div class="splash-logo pulse-animation">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/>
                <circle cx="12" cy="10" r="3"/>
            </svg>
        </div>
        <h1 class="splash-title">WilayahKu</h1>
        <p class="splash-tagline">Satu Portal, Seluruh Nusantara.</p>
        <p class="splash-desc">
            Temukan data wilayah administrasi Indonesia mulai dari Provinsi hingga Desa dengan cepat, akurat, dan terpercaya.
        </p>
        
        <div class="splash-actions mt-4">
            <a href="/login" class="btn btn-masuk">
                Masuk
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
            <a href="/register" class="btn btn-daftar">
                Daftar Akun
            </a>
        </div>
    </div>
</div>

<style>
    .splash-wrapper {
        position: relative;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        min-height: 100vh;
        background: linear-gradient(135deg, #f3e7e9 0%, #e3eeff 99%, #e3eeff 100%);
        overflow: hidden;
        font-family: 'Inter', system-ui, sans-serif;
    }
    
    [data-theme='dark'] .splash-wrapper {
        background: linear-gradient(135deg, #1e130c 0%, #9a8478 100%);
    }

    /* Abstract background shapes */
    .blob {
        position: absolute;
        filter: blur(80px);
        z-index: 0;
        opacity: 0.6;
    }
    .blob-1 {
        top: -10%; left: -10%; width: 400px; height: 400px;
        background: #ff9a9e;
        animation: float 10s ease-in-out infinite alternate;
    }
    .blob-2 {
        bottom: -20%; right: -10%; width: 500px; height: 500px;
        background: #a1c4fd;
        animation: float 12s ease-in-out infinite alternate-reverse;
    }
    .blob-3 {
        top: 20%; right: 20%; width: 300px; height: 300px;
        background: #fecfef;
        animation: float 8s ease-in-out infinite alternate;
    }

    [data-theme='dark'] .blob-1 { background: #431e34; }
    [data-theme='dark'] .blob-2 { background: #1c3659; }
    [data-theme='dark'] .blob-3 { background: #4d3a2b; }

    @@keyframes float {
        0% { transform: translateY(0) scale(1); }
        100% { transform: translateY(50px) scale(1.1); }
    }

    .splash-content-box {
        position: relative;
        z-index: 10;
        max-width: 650px;
        text-align: center;
        background: rgba(255, 255, 255, 0.65);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        padding: 4rem 3rem;
        border-radius: 32px;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.08);
        border: 1px solid rgba(255, 255, 255, 0.4);
    }

    [data-theme='dark'] .splash-content-box {
        background: rgba(20, 20, 20, 0.6);
        border: 1px solid rgba(255, 255, 255, 0.05);
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
    }

    .splash-logo {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 90px;
        height: 90px;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border-radius: 28px;
        margin-bottom: 2rem;
        box-shadow: 0 15px 30px rgba(118, 75, 162, 0.3);
    }

    .splash-title {
        font-size: 3.5rem;
        font-weight: 900;
        margin-bottom: 0.5rem;
        background: linear-gradient(to right, #2b5876 0%, #4e4376 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        letter-spacing: -0.05em;
    }

    [data-theme='dark'] .splash-title {
        background: linear-gradient(to right, #e0c3fc 0%, #8ec5fc 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .splash-tagline {
        font-size: 1.5rem;
        font-weight: 600;
        color: #4b5563;
        margin-bottom: 1.5rem;
    }

    [data-theme='dark'] .splash-tagline { color: #d1d5db; }

    .splash-desc {
        font-size: 1.15rem;
        line-height: 1.7;
        color: #6b7280;
        margin-bottom: 3rem;
        max-width: 90%;
        margin-left: auto;
        margin-right: auto;
    }

    [data-theme='dark'] .splash-desc { color: #9ca3af; }

    .splash-actions {
        display: flex;
        gap: 1.25rem;
        justify-content: center;
        flex-wrap: wrap;
    }

    .btn-masuk {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        font-weight: 700;
        padding: 1rem 2.5rem;
        border-radius: 999px;
        font-size: 1.125rem;
        transition: all 0.3s ease;
        border: none;
        box-shadow: 0 10px 20px rgba(118, 75, 162, 0.25);
    }
    
    .btn-masuk:hover {
        transform: translateY(-3px);
        box-shadow: 0 15px 25px rgba(118, 75, 162, 0.4);
        color: white;
    }

    .btn-daftar {
        display: inline-flex;
        align-items: center;
        background: rgba(255, 255, 255, 0.8);
        color: #4e4376;
        font-weight: 700;
        padding: 1rem 2.5rem;
        border-radius: 999px;
        font-size: 1.125rem;
        transition: all 0.3s ease;
        border: 2px solid transparent;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.05);
    }

    [data-theme='dark'] .btn-daftar {
        background: rgba(0, 0, 0, 0.3);
        color: #e0c3fc;
        border: 1px solid rgba(255,255,255,0.1);
    }
    
    .btn-daftar:hover {
        background: white;
        border-color: #e0c3fc;
        transform: translateY(-3px);
        box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1);
    }

    [data-theme='dark'] .btn-daftar:hover {
        background: rgba(255,255,255,0.1);
    }

    /* Animations */
    .fade-in-up {
        animation: fadeInUp 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
    
    .pulse-animation {
        animation: subtlePulse 3s infinite alternate;
    }

    @@keyframes fadeInUp {
        from { opacity: 0; transform: translateY(40px); }
        to { opacity: 1; transform: translateY(0); }
    }

    @@keyframes subtlePulse {
        0% { transform: scale(1); }
        100% { transform: scale(1.05); }
    }
</style>

@code {
    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        if (authState.User.Identity?.IsAuthenticated == true)
        {
            Nav.NavigateTo("/akun");
        }
    }
}
