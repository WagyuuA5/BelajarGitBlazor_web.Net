@page "/about"
@page "/tentang-kami"

<PageTitle>Tentang Kami – WilayahKu</PageTitle>

<!-- Hero Section -->
<div class="about-hero">
    <div class="about-hero-header">
        <div class="hero-eyebrow">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/>
                <path d="m9 12 2 2 4-4"/>
            </svg>
            <span>Direktori Informasi Publik</span>
        </div>
        <h1 class="about-hero-title">
            Portal Data Wilayah <br />
            <span class="highlight">Administrasi Indonesia</span>
        </h1>
        <p class="about-hero-desc">
            WilayahKu dirancang sebagai pusat informasi kode dan nama wilayah administrasi di Indonesia, mulai dari tingkat Provinsi, Kabupaten/Kota, Kecamatan, hingga Kelurahan/Desa. Data bersumber dari <strong>wilayah.id</strong> yang mengacu pada data resmi Kepmendagri.
        </p>
    </div>

    <div class="about-stats-grid">
        <div class="about-stat-card">
            <div class="about-stat-icon">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/>
                </svg>
            </div>
            <div>
                <div class="about-stat-number">38 Provinsi</div>
                <div class="about-stat-label">Cakupan Nasional</div>
            </div>
        </div>

        <div class="about-stat-card">
            <div class="about-stat-icon" style="background: var(--warning-light); color: var(--warning);">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/>
                </svg>
            </div>
            <div>
                <div class="about-stat-number">500+ Kab/Kota</div>
                <div class="about-stat-label">Data Terverifikasi</div>
            </div>
        </div>

        <div class="about-stat-card">
            <div class="about-stat-icon" style="background: var(--success-light); color: var(--success);">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
                </svg>
            </div>
            <div>
                <div class="about-stat-number">7.000+ Kecamatan</div>
                <div class="about-stat-label">Selalu Diperbarui</div>
            </div>
        </div>

        <div class="about-stat-card">
            <div class="about-stat-icon" style="background: rgba(6, 182, 212, 0.12); color: var(--accent);">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M3 3v18h18"/><path d="m19 9-5 5-4-4-3 3"/>
                </svg>
            </div>
            <div>
                <div class="about-stat-number">80.000+ Desa</div>
                <div class="about-stat-label">Kelurahan/Desa Tercakup</div>
            </div>
        </div>
    </div>
</div>

<!-- Sumber & Keandalan Data Section -->
<div class="section-header">
    <div class="section-title-wrap">
        <div class="section-title-icon" style="background: var(--warning-light); color: var(--warning);">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5v14a9 3 0 0 0 18 0V5"/><path d="M3 12a9 3 0 0 0 18 0"/>
            </svg>
        </div>
        <h2 class="section-title">Sumber & Keandalan Data</h2>
    </div>
    <p class="section-subtitle">Bagaimana kami menjaga data tetap akurat dan dapat dipercaya.</p>
</div>

<div class="tech-grid">
    <div class="tech-card">
        <div class="tech-card-header">
            <div class="tech-icon-wrap tech-icon-blazor">
                <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                </svg>
            </div>
            <div>
                <h3 class="tech-card-title">Sumber Resmi</h3>
                <span class="tech-card-badge">wilayah.id & Kepmendagri</span>
            </div>
        </div>

        <p class="tech-card-desc">
            Seluruh data kode wilayah kami ambil dari wilayah.id, yang mengacu pada Keputusan Menteri Dalam Negeri
            tentang Kode dan Data Wilayah Administrasi Pemerintahan.
        </p>

        <ul class="tech-features-list">
            <li class="tech-feature-item">
                <svg class="tech-feature-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                <span>Rujukan resmi Kepmendagri</span>
            </li>
            <li class="tech-feature-item">
                <svg class="tech-feature-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                <span>Cakupan seluruh wilayah Indonesia</span>
            </li>
        </ul>
    </div>

    <div class="tech-card">
        <div class="tech-card-header">
            <div class="tech-icon-wrap tech-icon-dotnet">
                <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/>
                </svg>
            </div>
            <div>
                <h3 class="tech-card-title">Validasi Berkala</h3>
                <span class="tech-card-badge">Kontrol Kualitas Data</span>
            </div>
        </div>

        <p class="tech-card-desc">
            Kami rutin memeriksa konsistensi data — memastikan setiap kecamatan memiliki induk kabupaten yang benar,
            dan setiap kode wilayah sesuai hierarki resminya.
        </p>

        <ul class="tech-features-list">
            <li class="tech-feature-item">
                <svg class="tech-feature-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                <span>Pemeriksaan hierarki wilayah</span>
            </li>
            <li class="tech-feature-item">
                <svg class="tech-feature-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                <span>Sinkronisasi berkala dengan sumber</span>
            </li>
        </ul>
    </div>

    <div class="tech-card">
        <div class="tech-card-header">
            <div class="tech-icon-wrap tech-icon-git">
                <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
                </svg>
            </div>
            <div>
                <h3 class="tech-card-title">Akses Cepat</h3>
                <span class="tech-card-badge">Gratis & Tanpa Login</span>
            </div>
        </div>

        <p class="tech-card-desc">
            Cari kode wilayah kapan saja tanpa perlu mendaftar. Hasil pencarian ditampilkan instan dengan opsi
            salin kode langsung ke clipboard.
        </p>

        <ul class="tech-features-list">
            <li class="tech-feature-item">
                <svg class="tech-feature-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                <span>Tanpa biaya, tanpa registrasi</span>
            </li>
            <li class="tech-feature-item">
                <svg class="tech-feature-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                <span>Salin kode dengan satu klik</span>
            </li>
        </ul>
    </div>
</div>

<!-- Komitmen Kami Section -->
<div class="section-header">
    <div class="section-title-wrap">
        <div class="section-title-icon" style="background: var(--success-light); color: var(--success);">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/>
            </svg>
        </div>
        <h2 class="section-title">Komitmen Kami</h2>
    </div>
    <p class="section-subtitle">Nilai yang kami pegang dalam menyajikan data wilayah kepada Anda.</p>
</div>

<div class="principles-grid">
    <div class="principle-card">
        <div class="principle-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="m9 12 2 2 4-4"/><circle cx="12" cy="12" r="10"/>
            </svg>
        </div>
        <h3 class="principle-title">Data Akurat</h3>
        <p class="principle-desc">Setiap kode wilayah kami sajikan sesuai rujukan resmi, tanpa perubahan sepihak.</p>
    </div>

    <div class="principle-card" style="--hover-color: var(--warning);">
        <div class="principle-icon" style="color: var(--warning); background: var(--warning-light);">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M13 2 3 14h9l-1 8 10-12h-9l1-8z"/>
            </svg>
        </div>
        <h3 class="principle-title">Akses Cepat & Gratis</h3>
        <p class="principle-desc">Tidak ada biaya atau proses pendaftaran. Cari dan temukan kode wilayah dalam hitungan detik.</p>
    </div>

    <div class="principle-card" style="--hover-color: var(--accent);">
        <div class="principle-icon" style="color: var(--accent); background: rgba(6, 182, 212, 0.12);">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 12a9 9 0 1 1-6.219-8.56"/><path d="M12 7v5l3 3"/>
            </svg>
        </div>
        <h3 class="principle-title">Selalu Diperbarui</h3>
        <p class="principle-desc">Kami memantau perubahan data wilayah administrasi dan memperbarui basis data secara berkala.</p>
    </div>
</div>

<!-- Developer Team Section (dipindah ke bawah) -->
<div class="section-header">
    <div class="section-title-wrap">
        <div class="section-title-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                <circle cx="9" cy="7" r="4"/>
                <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
            </svg>
        </div>
        <h2 class="section-title">Tim Developer</h2>
    </div>
    <p class="section-subtitle">Para pengembang muda berbakat yang berkolaborasi membangun portal ini.</p>
</div>

<div class="team-grid">
    <!-- Choqie Alfaro -->
    <div class="team-card">
        <div class="team-card-banner"></div>
        <div class="team-profile">
            <div class="team-avatar">CA</div>
            <div>
                <h3 class="team-info-name">Choqie Alfaro</h3>
                <div class="team-info-role">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                        <path d="M20 7h-7L10 4H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2z"/>
                    </svg>
                    <span>UI/UX Developer</span>
                </div>
                <div class="team-info-meta">Tahun Kelahiran: 2009</div>
            </div>
        </div>

        <p class="team-bio">
            Fokus pada perancangan antarmuka yang intuitif dan responsif, memastikan pengalaman pencarian wilayah terasa mudah dan nyaman bagi semua pengguna.
        </p>

        <div class="team-tags">
            <span class="team-tag">UI/UX Design</span>
            <span class="team-tag">Frontend</span>
            <span class="team-tag">Aksesibilitas</span>
            <span class="team-tag">Responsive</span>
        </div>
    </div>

    <!-- Wahyu Ravi -->
    <div class="team-card" style="--hover-color: var(--accent);">
        <div class="team-card-banner accent"></div>
        <div class="team-profile">
            <div class="team-avatar teal">WR</div>
            <div>
                <h3 class="team-info-name">Wahyu Ravi</h3>
                <div class="team-info-role" style="color: var(--accent);">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                        <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/>
                        <line x1="8" y1="21" x2="16" y2="21"/>
                        <line x1="12" y1="17" x2="12" y2="21"/>
                    </svg>
                    <span>Backend & Data Engineer</span>
                </div>
                <div class="team-info-meta">Tahun Kelahiran: 2008</div>
            </div>
        </div>

        <p class="team-bio">
            Bertanggung jawab dalam pengelolaan arsitektur data wilayah, optimalisasi performa pencarian, serta memastikan keandalan dan keakuratan data yang ditampilkan.
        </p>

        <div class="team-tags">
            <span class="team-tag">Backend</span>
            <span class="team-tag">Data Pipeline</span>
            <span class="team-tag">Performa</span>
            <span class="team-tag">Arsitektur</span>
        </div>
    </div>
</div>

<!-- CTA Banner -->
<div class="about-cta">
    <div>
        <h3 class="about-cta-title">Ingin Berdiskusi atau Melaporkan Data?</h3>
        <p class="about-cta-desc">Jangan ragu untuk menghubungi kami jika ada pertanyaan, saran, atau temuan data yang tidak sesuai.</p>
    </div>
    <div style="display: flex; gap: 12px; flex-wrap: wrap;">
        <a href="contact" class="btn btn-primary btn-lg">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
            Hubungi Kami
        </a>
        <a href="" class="btn btn-secondary btn-lg" style="background: rgba(255,255,255,0.08); color: #fff; border-color: rgba(255,255,255,0.18);">
            Cari Data Wilayah
        </a>
    </div>
</div>
