@page "/about"
@page "/tentang-kami"

<PageTitle>Tentang Kami BelajarGitBlazor</PageTitle>

<!-- Hero Section -->
<div class="about-hero">
    <div class="about-hero-header">
        <div class="hero-eyebrow">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/>
                <path d="m9 12 2 2 4-4"/>
            </svg>
            <span>Projek Kolaboratif .NET</span>
        </div>

        <h1 class="about-hero-title">
            Membangun Web Modern dengan <br />
            <span class="highlight">Git & Blazor Framework</span>
        </h1>

        <p class="about-hero-desc">
            Project ini dirancang sebagai platform latihan dan eksplorasi kolaborasi pengembangan web interaktif 
            menggunakan ekosistem C#, .NET 8, serta penerapan alur kontrol versi Git secara profesional.
        </p>
    </div>

    <div class="about-stats-grid">
        <div class="about-stat-card">
            <div class="about-stat-icon">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/>
                    <circle cx="9" cy="7" r="4"/>
                    <path d="M22 21v-2a4 4 0 0 0-3-3.87"/>
                    <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                </svg>
            </div>
            <div>
                <div class="about-stat-number">2 Devs</div>
                <div class="about-stat-label">Tim Collab</div>
            </div>
        </div>

        <div class="about-stat-card">
            <div class="about-stat-icon" style="background: var(--warning-light); color: var(--warning);">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
                </svg>
            </div>
            <div>
                <div class="about-stat-number">.NET 8</div>
                <div class="about-stat-label">Target Framework</div>
            </div>
        </div>

        <div class="about-stat-card">
            <div class="about-stat-icon" style="background: var(--success-light); color: var(--success);">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="16 18 22 12 16 6"/>
                    <polyline points="8 6 2 12 8 18"/>
                </svg>
            </div>
            <div>
                <div class="about-stat-number">100% C#</div>
                <div class="about-stat-label">Fullstack Logic</div>
            </div>
        </div>

        <div class="about-stat-card">
            <div class="about-stat-icon" style="background: rgba(6, 182, 212, 0.12); color: var(--accent);">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="6" y1="3" x2="6" y2="15"/>
                    <circle cx="18" cy="6" r="3"/>
                    <circle cx="6" cy="18" r="3"/>
                    <path d="M18 9a9 9 0 0 1-9 9"/>
                </svg>
            </div>
            <div>
                <div class="about-stat-number">Git VCS</div>
                <div class="about-stat-label">Distributed Control</div>
            </div>
        </div>
    </div>
</div>

<!-- Developer Team Section -->
<div class="section-header">
    <div class="section-title-wrap">
        <div class="section-title-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                <circle cx="9" cy="7" r="4"/>
                <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
            </svg>
        </div>
        <h2 class="section-title">Tim Developer</h2>
    </div>
    <p class="section-subtitle">Para pengembang muda berbakat yang berkolaborasi membangun projek ini.</p>
</div>

<div class="team-grid">
    <!-- Choqie Alfaro -->
    <div class="team-card">
        <div class="team-card-banner"></div>
        <div class="team-profile">
            <div class="team-avatar">CA</div>
            <div>
                <h3 class="team-info-name">Choqie Alfaro</h3>
                <div class="team-info-role">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                        <path d="M20 7h-7L10 4H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2z"/>
                    </svg>
                    <span>Fullstack Developer</span>
                </div>
                <div class="team-info-meta">Tahun Kelahiran: 2009</div>
            </div>
        </div>

        <p class="team-bio">
            Fokus pada perancangan komponen antarmuka pengguna Blazor yang interaktif, integrasi alur kerja Git, 
            serta memastikan pengalaman pengguna tetap intuitif dan responsif.
        </p>

        <div class="team-tags">
            <span class="team-tag">Blazor UI</span>
            <span class="team-tag">C# Expert</span>
            <span class="team-tag">Git Flow</span>
            <span class="team-tag">UX Design</span>
        </div>
    </div>

    <!-- Wahyu Ravi -->
    <div class="team-card" style="--hover-color: var(--accent);">
        <div class="team-card-banner accent"></div>
        <div class="team-profile">
            <div class="team-avatar teal">WR</div>
            <div>
                <h3 class="team-info-name">Wahyu Ravi</h3>
                <div class="team-info-role" style="color: var(--accent);">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                        <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/>
                        <line x1="8" y1="21" x2="16" y2="21"/>
                        <line x1="12" y1="17" x2="12" y2="21"/>
                    </svg>
                    <span>System & Core Dev</span>
                </div>
                <div class="team-info-meta">Tahun Kelahiran: 2008</div>
            </div>
        </div>

        <p class="team-bio">
            Bertanggung jawab dalam mengelola struktur arsitektur .NET 8, optimalisasi logika aplikasi, 
            serta memastikan modularitas kode bersih dan mudah dipelihara.
        </p>

        <div class="team-tags">
            <span class="team-tag">.NET 8 Core</span>
            <span class="team-tag">System Arch</span>
            <span class="team-tag">Clean Code</span>
            <span class="team-tag">State Management</span>
        </div>
    </div>
</div>

<!-- Technology Stack Section -->
<div class="section-header">
    <div class="section-title-wrap">
        <div class="section-title-icon" style="background: var(--warning-light); color: var(--warning);">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polygon points="12 2 2 7 12 12 22 7 12 2"/>
                <polyline points="2 17 12 22 22 17"/>
                <polyline points="2 12 12 17 22 12"/>
            </svg>
        </div>
        <h2 class="section-title">Teknologi Utama</h2>
    </div>
    <p class="section-subtitle">Fondasi teknologi modern yang mendukung performa dan keandalan aplikasi.</p>
</div>

<div class="tech-grid">
    <!-- Blazor -->
    <div class="tech-card">
        <div class="tech-card-header">
            <div class="tech-icon-wrap tech-icon-blazor">
                <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
                </svg>
            </div>
            <div>
                <h3 class="tech-card-title">Blazor</h3>
                <span class="tech-card-badge">Microsoft Web Framework</span>
            </div>
        </div>
        
        <p class="tech-card-desc">
            Framework web modern buatan Microsoft yang memungkinkan pembuatan antarmuka web Single Page Application (SPA) 
            interaktif menggunakan C# dan HTML tanpa tergantung pada JavaScript pihak ketiga.
        </p>

        <ul class="tech-features-list">
            <li class="tech-feature-item">
                <svg class="tech-feature-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                <span>Interactive Server Components</span>
            </li>
            <li class="tech-feature-item">
                <svg class="tech-feature-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                <span>Arsitektur Komponen Reusable</span>
            </li>
            <li class="tech-feature-item">
                <svg class="tech-feature-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                <span>Full Type-Safety C# di UI</span>
            </li>
        </ul>
    </div>

    <!-- .NET 8 -->
    <div class="tech-card">
        <div class="tech-card-header">
            <div class="tech-icon-wrap tech-icon-dotnet">
                <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="2" y="2" width="20" height="8" rx="2"/>
                    <rect x="2" y="14" width="20" height="8" rx="2"/>
                    <line x1="6" y1="6" x2="6.01" y2="6"/>
                    <line x1="6" y1="18" x2="6.01" y2="18"/>
                </svg>
            </div>
            <div>
                <h3 class="tech-card-title">.NET 8</h3>
                <span class="tech-card-badge">Long-Term Support (LTS)</span>
            </div>
        </div>

        <p class="tech-card-desc">
            Platform pengembang Microsoft versi LTS terbaru yang menawarkan ekosistem super cepat, aman, dan efisien 
            untuk membangun berbagai solusi perangkat lunak modern.
        </p>

        <ul class="tech-features-list">
            <li class="tech-feature-item">
                <svg class="tech-feature-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                <span>Performa Tinggi & Native Optimization</span>
            </li>
            <li class="tech-feature-item">
                <svg class="tech-feature-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                <span>Dukungan Jangka Panjang (LTS)</span>
            </li>
            <li class="tech-feature-item">
                <svg class="tech-feature-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                <span>Ekosistem NuGet Terintegrasi</span>
            </li>
        </ul>
    </div>

    <!-- Git -->
    <div class="tech-card">
        <div class="tech-card-header">
            <div class="tech-icon-wrap tech-icon-git">
                <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="6" y1="3" x2="6" y2="15"/>
                    <circle cx="18" cy="6" r="3"/>
                    <circle cx="6" cy="18" r="3"/>
                    <path d="M18 9a9 9 0 0 1-9 9"/>
                </svg>
            </div>
            <div>
                <h3 class="tech-card-title">Git</h3>
                <span class="tech-card-badge">Distributed Version Control</span>
            </div>
        </div>

        <p class="tech-card-desc">
            Sistem pengontrol versi terdistribusi standar industri yang digunakan untuk melacak riwayat perubahan kode, 
            memfasilitasi kolaborasi multi-developer, serta mengamankan riwayat projek.
        </p>

        <ul class="tech-features-list">
            <li class="tech-feature-item">
                <svg class="tech-feature-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                <span>Distributed Branching & Merging</span>
            </li>
            <li class="tech-feature-item">
                <svg class="tech-feature-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                <span>History Audit & Rollback Aman</span>
            </li>
            <li class="tech-feature-item">
                <svg class="tech-feature-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                <span>Kolaborasi Tim Bebas Konflik</span>
            </li>
        </ul>
    </div>
</div>

<!-- Core Principles Section -->
<div class="section-header">
    <div class="section-title-wrap">
        <div class="section-title-icon" style="background: var(--success-light); color: var(--success);">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/>
                <path d="M12 16v-4"/>
                <path d="M12 8h.01"/>
            </svg>
        </div>
        <h2 class="section-title">Prinsip Pengembangan</h2>
    </div>
    <p class="section-subtitle">Nilai-nilai utama yang kami terapkan dalam memodelkan aplikasi ini.</p>
</div>

<div class="principles-grid">
    <div class="principle-card">
        <div class="principle-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
                <polyline points="3.27 6.96 12 12.01 20.73 6.96"/>
                <line x1="12" y1="22.08" x2="12" y2="12"/>
            </svg>
        </div>
        <h3 class="principle-title">Kode Terstruktur</h3>
        <p class="principle-desc">Pemisahan komponen dan layout yang bersih memudahkan eskalasi serta pemeliharaan kode jangka panjang.</p>
    </div>

    <div class="principle-card" style="--hover-color: var(--warning);">
        <div class="principle-icon" style="color: var(--warning); background: var(--warning-light);">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="5"/>
                <line x1="12" y1="1" x2="12" y2="3"/>
                <line x1="12" y1="21" x2="12" y2="23"/>
                <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
                <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
                <line x1="1" y1="12" x2="3" y2="12"/>
                <line x1="21" y1="12" x2="23" y2="12"/>
                <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
                <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
            </svg>
        </div>
        <h3 class="principle-title">Desain Adaptif</h3>
        <p class="principle-desc">Mendukung tema Light, Dark, dan Purple secara interaktif dengan sistem warna yang estetis.</p>
    </div>

    <div class="principle-card" style="--hover-color: var(--accent);">
        <div class="principle-icon" style="color: var(--accent); background: rgba(6, 182, 212, 0.12);">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
        </div>
        <h3 class="principle-title">Kolaborasi Git Safely</h3>
        <p class="principle-desc">Penerapan standar commit & merge untuk menjaga stabilitas master branch selama fase iterasi.</p>
    </div>
</div>

<!-- CTA Banner -->
