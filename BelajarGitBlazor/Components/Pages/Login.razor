@page "/login"
@inject NavigationManager Nav
@layout Components.Layout.EmptyLayout

<PageTitle>Login – WilayahKu</PageTitle>

<div class="auth-container">
    <div class="auth-card">
        <h1 class="auth-title">Selamat Datang</h1>
        <p class="auth-subtitle">Masuk ke akun WilayahKu kamu</p>

        <form method="post" action="/api/auth/login" data-enhance="false">
            <AntiforgeryToken />
            
            <div class="form-group">
                <label class="form-label" for="username">
                    Username <span class="required">*</span>
                </label>
                <div class="input-group">
                    <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
                    </svg>
                    <input class="form-input"
                           id="username"
                           name="username"
                           type="text"
                           placeholder="jokowidodo"
                           required />
                </div>
            </div>

            <div class="form-group">
                <label class="form-label" for="password">
                    Password <span class="required">*</span>
                </label>
                <div class="input-group">
                    <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                    </svg>
                    <input class="form-input"
                           id="password"
                           name="password"
                           type="password"
                           placeholder="••••••••"
                           required />
                </div>
            </div>

            <div class="form-group">
                <label class="checkbox-group">
                    <input type="checkbox" id="rememberMe" name="rememberMe" value="true" />
                    <span class="checkbox-label">Ingat saya di perangkat ini (Simpan Sesi)</span>
                </label>
            </div>

            <button type="submit" class="btn btn-primary" id="login-btn" style="width:100%;">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" x2="3" y1="12" y2="12"/>
                </svg>
                <span>Masuk</span>
            </button>
        </form>

        <div class="form-divider">atau</div>

        <p class="auth-footer">
            Belum punya akun? <a href="/register" id="goto-register">Daftar sekarang</a>
        </p>

        <div style="margin-top:20px; padding:14px; background:var(--surface-alt); border-radius:var(--radius-sm); border:1px solid var(--border);">
            <p style="font-size:0.75rem; color:var(--text-muted); margin:0 0 6px; font-weight:600;">Demo Akun Admin:</p>
            <p style="font-size:0.75rem; color:var(--text-muted); margin:0;">Username: admin_wilayahku</p>
            <p style="font-size:0.75rem; color:var(--text-muted); margin:0;">Password: adminpassword123</p>
        </div>
    </div>
</div>
