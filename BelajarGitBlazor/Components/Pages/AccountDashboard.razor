@page "/akun"
@rendermode InteractiveServer
@inject AuthService AuthService
@inject NavigationManager Nav

<PageTitle>Dashboard Akun – WilayahKu</PageTitle>

@if (!AuthService.IsAuthenticated)
{
    // Guard: redirect ke login jika belum login
    Nav.NavigateTo("/login");
    return;
}

@{
    var user = AuthService.CurrentUser!;
    var initials = GetInitials(user.Name);
}

<div class="dashboard-container">

    @* ===== PROFILE CARD ===== *@
    <div class="dashboard-profile-card">
        <div class="dashboard-avatar" aria-label="Avatar @user.Name">@initials</div>
        <div class="dashboard-profile-info">
            <h1 class="dashboard-profile-name">@user.Name</h1>
            <p class="dashboard-profile-email">@user.Email</p>
            <span class="dashboard-profile-badge">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <path d="m9 12 2 2 4-4"/><circle cx="12" cy="12" r="10"/>
                </svg>
                Akun Aktif
            </span>
        </div>
    </div>

    @* ===== STATISTIK ===== *@
    <div>
        <h2 class="dashboard-section-title">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 3v18h18"/><path d="m19 9-5 5-4-4-3 3"/>
            </svg>
            Statistik Pencarian
        </h2>
        <div class="dashboard-stats-grid">
            <div class="dashboard-stat-card" style="--stat-color: var(--primary);">
                <div class="dashboard-stat-icon">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>
                    </svg>
                </div>
                <div class="dashboard-stat-value" id="stat-today">12</div>
                <div class="dashboard-stat-label">Pencarian hari ini</div>
            </div>

            <div class="dashboard-stat-card" style="--stat-color: var(--warning);">
                <div class="dashboard-stat-icon">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
                    </svg>
                </div>
                <div class="dashboard-stat-value" id="stat-total">47</div>
                <div class="dashboard-stat-label">Total pencarian</div>
            </div>

            <div class="dashboard-stat-card" style="--stat-color: var(--success);">
                <div class="dashboard-stat-icon">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect width="14" height="14" x="8" y="8" rx="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/>
                    </svg>
                </div>
                <div class="dashboard-stat-value" id="stat-copied">8</div>
                <div class="dashboard-stat-label">Kode disalin</div>
            </div>

            <div class="dashboard-stat-card" style="--stat-color: var(--accent);">
                <div class="dashboard-stat-icon">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/>
                    </svg>
                </div>
                <div class="dashboard-stat-value" id="stat-province">Jawa Barat</div>
                <div class="dashboard-stat-label">Provinsi terbanyak dicari</div>
            </div>
        </div>
    </div>

    @* ===== PENCARIAN TERAKHIR ===== *@
    <div class="dashboard-recent-card">
        <h2 class="dashboard-section-title">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
            </svg>
            Pencarian Terakhir
        </h2>
        <div class="dashboard-recent-empty">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="margin: 0 auto 12px; display: block; opacity: 0.4;">
                <circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>
            </svg>
            <p style="margin: 0;">Belum ada pencarian yang tersimpan.</p>
            <p style="margin: 4px 0 0; font-size: 0.78rem; opacity: 0.7;">Riwayat akan muncul di sini setelah kamu mencari wilayah.</p>
        </div>
    </div>

    @* ===== TOMBOL AKSI ===== *@
    <div class="dashboard-actions-row">
        <a href="/data-wilayah" class="btn btn-primary" id="btn-cari-wilayah">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>
            </svg>
            Cari Wilayah
        </a>
        <button class="btn btn-secondary" id="btn-logout" @onclick="HandleLogout">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/>
            </svg>
            Keluar
        </button>
    </div>
</div>

@code {
    private void HandleLogout()
    {
        AuthService.Logout();
        Nav.NavigateTo("/login");
    }

    private static string GetInitials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "??";
        var words = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (words.Length == 1) return words[0][..Math.Min(2, words[0].Length)].ToUpper();
        return $"{words[0][0]}{words[^1][0]}".ToUpper();
    }
}
