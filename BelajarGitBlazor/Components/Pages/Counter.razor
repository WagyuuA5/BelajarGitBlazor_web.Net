@page "/counter"
@rendermode InteractiveServer

<PageTitle>Counter – BelajarGitBlazor</PageTitle>

<div class="page-header">
    <h1>Interaktif Counter</h1>
    <p>Komponen stateful sederhana untuk mendemonstrasikan Blazor Server reactivity.</p>
</div>

<div class="card" style="text-align: center; padding: 48px 24px; max-width: 500px; margin: 0 auto;">
    
    <div class="counter-display">
        <span class="counter-number @(_isBumped ? "bump" : "")">@currentCount</span>
        <span class="counter-label">Klik</span>
    </div>

    <div class="counter-controls">
        <button class="btn btn-primary btn-lg" @onclick="IncrementCount">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5v14"/></svg>
            Tambah Nilai
        </button>
        
        <button class="btn btn-secondary btn-lg" @onclick="ResetCount" disabled="@(currentCount == 0)">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/></svg>
            Reset
        </button>
    </div>
    
    <div style="margin-top: 36px; padding-top: 24px; border-top: 1px solid var(--border); font-size: 0.85rem; color: var(--text-muted);">
        Nilai saat ini disimpan di memori server. Jika Anda refresh halaman, nilai akan kembali ke 0.
    </div>
</div>

@code {
    private int currentCount = 0;
    private bool _isBumped = false;

    private async Task IncrementCount()
    {
        currentCount++;
        _isBumped = true;
        await Task.Delay(150);
        _isBumped = false;
    }

    private async Task ResetCount()
    {
        currentCount = 0;
        _isBumped = true;
        await Task.Delay(150);
        _isBumped = false;
    }
}
