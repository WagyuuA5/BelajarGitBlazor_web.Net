    }

    // === Dropdown Toggle ===
    private void ToggleDropdown(string name)
    {
        // Close all first
        bool wasOpen = name switch
        {
            nameof(showProvinsi) => showProvinsi,
            nameof(showKabupaten) => showKabupaten,
            nameof(showKecamatan) => showKecamatan,
            nameof(showKelurahan) => showKelurahan,
            _ => false
        };

        showProvinsi = false;
        showKabupaten = false;
        showKecamatan = false;
        showKelurahan = false;

        // Toggle the requested one
        switch (name)
        {
            case nameof(showProvinsi): showProvinsi = !wasOpen; break;
            case nameof(showKabupaten): showKabupaten = !wasOpen; break;
            case nameof(showKecamatan): showKecamatan = !wasOpen; break;
            case nameof(showKelurahan): showKelurahan = !wasOpen; break;
        }
    }

    private async Task CloseDropdownDelayed(string name)
    {
        await Task.Delay(200);
        switch (name)
        {
            case nameof(showProvinsi): showProvinsi = false; break;
            case nameof(showKabupaten): showKabupaten = false; break;
            case nameof(showKecamatan): showKecamatan = false; break;
            case nameof(showKelurahan): showKelurahan = false; break;
        }
        StateHasChanged();
    }

    // === Reset ===
    private void ResetAll()
    {
        selectedProvinsi = null;
        selectedKabupaten = null;
        selectedKecamatan = null;
        selectedKelurahan = null;
        kabupatenList = null;
        kecamatanList = null;
        kelurahanList = null;
        searchProvinsi = "";
        searchKabupaten = "";
        searchKecamatan = "";
        searchKelurahan = "";
        showProvinsi = false;
        showKabupaten = false;
        showKecamatan = false;
        showKelurahan = false;
        errorMessage = null;
    }

    // === Filter ===
    private WilayahItem[] FilterList(WilayahItem[] list, string search)
    {
        if (string.IsNullOrWhiteSpace(search)) return list;
        var lower = search.Trim().ToLowerInvariant();
        return list.Where(x =>
            x.Name.ToLowerInvariant().Contains(lower) ||
            x.Code.ToLowerInvariant().Contains(lower)
        ).ToArray();
    }

    // === Copy to Clipboard ===
    private async Task CopyToClipboard(string text)
    {
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", text);
            copyFeedback = text;
            StateHasChanged();

            // Auto-hide toast after 2 seconds
            toastTimer?.Dispose();
            toastTimer = new System.Timers.Timer(2000);
            toastTimer.Elapsed += (s, e) =>
            {
                copyFeedback = null;
                toastTimer?.Dispose();
                InvokeAsync(StateHasChanged);
            };
            toastTimer.AutoReset = false;
            toastTimer.Start();
        }
        catch
        {
            // Clipboard API might fail in some contexts
        }
    }

    public void Dispose()
    {
        toastTimer?.Dispose();
    }

}
