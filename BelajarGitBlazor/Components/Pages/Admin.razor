@page "/admin"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using BelajarGitBlazor.Data
@using BelajarGitBlazor.Models
@attribute [Authorize(Roles = "Admin")]
@inject AppDbContext DbContext

<PageTitle>Admin Dashboard – WilayahKu</PageTitle>

<div class="admin-container mt-4">
    <div class="row">
        <!-- Kolom Utama: Manajemen Pengguna -->
        <div class="col-md-8">
            <h1 class="mb-4">Admin Dashboard</h1>
            <p>Halo Admin! Berikut adalah daftar akun yang terdaftar di sistem WilayahKu.</p>

            @if (_users == null)
            {
                <p><em>Memuat data pengguna...</em></p>
            }
            else
            {
                <div class="card shadow-sm p-3 mb-4 bg-white rounded">
                    <table class="table table-striped table-hover mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th>ID</th>
                                <th>Username</th>
                                <th>Role</th>
                                <th>Aksi</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var user in _users)
                            {
                                <tr>
                                    <td>@user.Id</td>
                                    <td>@user.Username</td>
                                    <td>
                                        @if(user.Role == "Admin")
                                        {
                                            <span class="badge bg-danger">@user.Role</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-primary">@user.Role</span>
                                        }
                                    </td>
                                    <td>
                                        @if(user.Role != "Admin")
                                        {
                                            <button class="btn btn-sm btn-danger" @onclick="() => HapusUser(user)">Hapus Akun</button>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>

        <!-- Sidebar: Notifikasi Pesan -->
        <div class="col-md-4">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">Pesan Masuk</h5>
                    <span class="badge bg-light text-primary rounded-pill">@_messages?.Count(m => !m.IsRead) Baru</span>
                </div>
                <div class="card-body p-0" style="max-height: 600px; overflow-y: auto;">
                    @if (_messages == null)
                    {
                        <div class="p-3 text-center"><em>Memuat pesan...</em></div>
                    }
                    else if (!_messages.Any())
                    {
                        <div class="p-4 text-center text-muted">
                            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="margin-bottom: 10px;">
                                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
                            </svg>
                            <p class="mb-0">Belum ada pesan dari pengguna.</p>
                        </div>
                    }
                    else
                    {
                        <div class="list-group list-group-flush">
                            @foreach (var msg in _messages.OrderByDescending(m => m.CreatedAt))
                            {
                                <div class="list-group-item list-group-item-action @(msg.IsRead ? "bg-light" : "")" style="border-left: @(msg.IsRead ? "4px solid transparent" : "4px solid var(--primary)");">
                                    <div class="d-flex w-100 justify-content-between">
                                        <h6 class="mb-1 fw-bold">@msg.SenderName</h6>
                                        <small class="text-muted">@msg.CreatedAt.ToLocalTime().ToString("dd MMM, HH:mm")</small>
                                    </div>
                                    <p class="mb-1 small">@msg.Content</p>
                                    <div class="d-flex justify-content-between align-items-center mt-2">
                                        <small class="text-primary">@msg.SenderEmail</small>
                                        @if (!msg.IsRead)
                                        {
                                            <button class="btn btn-sm btn-outline-secondary" @onclick="() => TandaiSudahDibaca(msg)">Tandai Dibaca</button>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private List<User>? _users;
    private List<Message>? _messages;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        _users = await DbContext.Users.ToListAsync();
        _messages = await DbContext.Messages.ToListAsync();
    }

    private async Task HapusUser(User user)
    {
        DbContext.Users.Remove(user);
        await DbContext.SaveChangesAsync();
        await LoadData();
    }

    private async Task TandaiSudahDibaca(Message msg)
    {
        msg.IsRead = true;
        DbContext.Messages.Update(msg);
        await DbContext.SaveChangesAsync();
        await LoadData();
    }
}
