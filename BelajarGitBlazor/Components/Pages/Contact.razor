@page "/contact"
@rendermode InteractiveServer

<PageTitle>Hubungi Kami – BelajarGitBlazor</PageTitle>

<div class="page-header">
    <h1>Hubungi Kami</h1>
    <p>Punya pertanyaan atau butuh bantuan? Kirimkan pesan atau hubungi kami melalui informasi di bawah.</p>
</div>

<div class="contact-grid">
    <div class="card">
        <h2 style="font-size:1.2rem; margin-bottom: 20px;">Kirim Pesan</h2>
        
        @if (_isSent)
        {
            <div class="alert alert-success">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                Pesan berhasil dikirim! Kami akan membalas secepatnya.
            </div>
            <button class="btn btn-outline" @onclick="() => _isSent = false" style="margin-top: 10px;">Kirim pesan baru</button>
        }
        else
        {
            <div class="form-group">
                <label class="form-label" for="contact-name">Nama Lengkap</label>
                <div class="input-group">
                    <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                    <input class="form-input" id="contact-name" type="text" placeholder="Nama kamu" @bind="_name" />
                </div>
            </div>

            <div class="form-group">
                <label class="form-label" for="contact-email">Email</label>
                <div class="input-group">
                    <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                    <input class="form-input" id="contact-email" type="email" placeholder="kamu@example.com" @bind="_email" />
                </div>
            </div>

            <div class="form-group">
                <label class="form-label" for="contact-message">Pesan</label>
                <textarea class="form-input" id="contact-message" rows="4" placeholder="Tulis pesan Anda di sini..." @bind="_message" style="padding-left: 14px;"></textarea>
            </div>

            <button class="btn btn-primary" @onclick="HandleSendAsync" disabled="@_isLoading">
                @if (_isLoading)
                {
                    <span class="spinner"></span>
                    <span>Mengirim...</span>
                }
                else
                {
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
                    <span>Kirim Pesan</span>
                }
            </button>
        }
    </div>

    <div>
        <div class="card" style="margin-bottom: 16px;">
            <div class="info-card-icon">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            </div>
            <h3 style="margin-bottom:4px;">Email</h3>
            <p style="margin:0;">PercobaanGit@gmail.com</p>
            <p style="font-size:0.8rem; margin: 4px 0 0;">Balasan dalam 24 jam kerja.</p>
        </div>

        <div class="card" style="margin-bottom: 16px;">
            <div class="info-card-icon" style="background: linear-gradient(135deg, var(--accent), var(--secondary));">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            </div>
            <h3 style="margin-bottom:4px;">No Telepon</h3>
            <p style="margin:0;">(021) 7884-6142</p>
            <p style="font-size:0.8rem; margin: 4px 0 0;">Senin - Jumat, 09:00 s/d 17:00</p>
        </div>

        <div class="card">
            <div class="info-card-icon" style="background: linear-gradient(135deg, var(--success), var(--accent));">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <h3 style="margin-bottom:4px;">Kantor Pusat</h3>
            <p style="margin:0;">PT Personel Alih Daya (Persada)</p>
            <p style="font-size:0.8rem; margin: 4px 0 0;">Jakarta Selatan, Indonesia</p>
        </div>
    </div>
</div>

@code {
    private string _name = "";
    private string _email = "";
    private string _message = "";
    private bool _isLoading = false;
    private bool _isSent = false;

    private async Task HandleSendAsync()
    {
        if (string.IsNullOrWhiteSpace(_name) || string.IsNullOrWhiteSpace(_email) || string.IsNullOrWhiteSpace(_message))
            return;

        _isLoading = true;
        await Task.Delay(1000); 
        _isLoading = false;
        _isSent = true;
        
        _name = "";
        _email = "";
        _message = "";
    }
}
